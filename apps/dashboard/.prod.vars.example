# ============================================
# FlareFilter — Production Secrets Template
# ============================================
# Copy this file to .prod.vars and fill in
# your real production values.
#
# Run `pnpm run deploy` to automatically push
# these to Cloudflare Workers secrets.
# ============================================

# Required: your production domain (no trailing slash)
BETTER_AUTH_BASE_URL="https://your-app.workers.dev"

# Required: a strong random secret (min 32 chars)
# Generate one: openssl rand -base64 32
BETTER_AUTH_SECRET=""

# Optional: enable email verification via Resend (https://resend.com).
# Get a free API key at resend.com (3k emails/month free).
RESEND_API_KEY=""
# Optional: from address (must be from a Resend-verified domain).
# Leave blank to use onboarding@resend.dev for testing.
RESEND_FROM="FlareFilter <noreply@yourdomain.com>"
